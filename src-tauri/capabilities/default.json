{
  "$schema": "https://schema.tauri.app/config/2/capability",
  "identifier": "default",
  "description": "Default permissions for CanvasFlow",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:default",
    "dialog:allow-save",
    "updater:default",
    "process:allow-restart",
    "notification:default",
    "notification:allow-notify"
  ]
}
