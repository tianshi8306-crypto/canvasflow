{
  "name": "canvasflow-ai-studio",
  "private": true,
  "version": "0.4.0",
  "license": "Apache-2.0",
  "description": "AI-powered video creation studio with infinite canvas workflow",
  "author": "CanvasFlow",
  "repository": {
    "type": "git",
    "url": "https://github.com/tianshi8306-crypto/canvasflow.git"
  },
  "homepage": "https://github.com/tianshi8306-crypto/canvasflow",
  "bugs": {
    "url": "https://github.com/tianshi8306-crypto/canvasflow/issues"
  },
  "keywords": [
    "ai",
    "video",
    "canvas",
    "tauri",
    "react",
    "workflow",
    "storyboard",
    "seedance"
  ],
  "type": "module",
  "scripts": {
    "dev": "vite",
    "desktop": "tauri dev --config src-tauri/tauri.dev.conf.json",
    "tauri:dev": "tauri dev --config src-tauri/tauri.dev.conf.json",
    "desktop:build:with-ffmpeg": "node scripts/tauri-build-with-ffmpeg.mjs",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "test:rust:integration": "cargo test --manifest-path src-tauri/Cargo.toml --test graph_integration_mock_llm",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "preview": "vite preview",
    "tauri": "tauri",
    "quality:gate": "npm run typecheck && npm run lint && npm run test:coverage && npm run test:rust",
    "quality:gate:full": "npm run typecheck && npm run lint && npm run test:coverage && npm run test:rust && npm run test:e2e",
    "release:check": "npm run quality:gate && npm run test:e2e:golden",
    "release:check:full": "npm run quality:gate:full",
    "test:e2e": "playwright test",
    "test:e2e:golden": "playwright test e2e/golden-path.spec.ts",
    "test:e2e:install": "playwright install chromium",
    "mcp:server": "node scripts/canvasflow-mcp-server.mjs",
    "icon:render": "node scripts/render-app-icon.mjs && tauri icon brand/app-icon-1024.png"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.99.0",
    "@tauri-apps/api": "^2.2.0",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@xyflow/react": "^12.4.2",
    "clsx": "^2.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tauri-apps/cli": "^2.2.7",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.19.19",
    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.1",
    "pdfjs-dist": "^5.7.284",
    "prettier": "^3.8.3",
    "sharp": "^0.34.5",
    "typescript": "~5.6.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^5.4.14",
    "vitest": "^4.1.5"
  }
}
